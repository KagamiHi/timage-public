ENV_FILE=.env

# Telegram API credentials — https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash
SESSION_NAME=session_name  # Telethon session file name for the catcher — can leave as-is

# Build
BUILD_TAG=local

# Django
DEBUG=1
# Not required for local (hardcoded in docker-compose.local.yaml)
# For ngrok: set to your static domain from https://dashboard.ngrok.com/domains
# For production: set to your server domain
EXTERNAL_HOST=your_domain_or_ngrok_url
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-change-in-production
SENTRY_DSN=  # Optional — get from https://sentry.io (create a project → DSN in Settings)

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_DB=db
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_PORT=5432

# MinIO (S3-compatible storage)
# Overridden to s3:9000 inside Docker — only matters when running Django outside containers
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme

# Redis
# Overridden to redis://redis:6379 inside Docker — only matters when running Django outside containers
REDIS_URL=redis://localhost:6379

# Telegram bot — create via https://t.me/BotFather
BOT_TOKEN=your_bot_token
WEBHOOK_SECRET=change-this-secret  # Any random string — sent by Telegram to verify webhook requests

# Local development: use long polling instead of webhooks
TLG_LONG_POLLING=1
